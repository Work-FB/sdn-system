">CREATE TABLE cuadres (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    usuario_id INTEGER,
    fecha TEXT,
    total_ventas REAL,
    total_efectivo REAL,
    diferencia REAL
)

SELECT * FROM cuadres

CREATE TABLE detalle_cuadre (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    cuadre_id INTEGER,
    denominacion TEXT,
    cantidad INTEGER,
    subtotal REAL
)

CREATE TABLE ventas (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    producto TEXT,
    precio REAL,
    fecha TEXT
)</sql><current_tab id="0"/></tab_sql></sqlb_project>
